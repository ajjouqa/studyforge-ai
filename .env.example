# --- Database (used by Prisma CLI via prisma.config.ts and by the app) ---
DATABASE_URL="file:./dev.db"

# --- AI via OpenRouter (required for summaries & flashcards) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model id in OpenRouter's "provider/model" format. Verify ids at
# https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet
# Optional per-task overrides (default to OPENROUTER_MODEL)
# OPENROUTER_MODEL_SUMMARY=anthropic/claude-3.7-sonnet
# OPENROUTER_MODEL_CARDS=openai/gpt-4o-mini

# --- App ---
APP_URL=http://localhost:3000
# Leave APP_PASSWORD empty to disable the login gate (frictionless local dev).
APP_PASSWORD=
AUTH_SECRET=change-me-to-a-long-random-string
STORAGE_DIR=./storage/uploads

# --- Audio transcription (OpenRouter has NO transcription endpoint) ---
# Uses an OpenAI-compatible Whisper API. Leave unset to disable audio uploads.
# OPENAI_API_KEY=
# Optional: point at a compatible provider (e.g. Groq) instead of OpenAI.
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# WHISPER_MODEL=whisper-1
